# Azure SQL Database (Prisma usa el provider "sqlserver")
DATABASE_URL="sqlserver://<server>.database.windows.net:1433;database=<db>;user=<user>;password=<password>;encrypt=true;trustServerCertificate=false"

# JWT
# En produccion (NODE_ENV=production) el arranque falla si estos secretos faltan, miden
# menos de 32 caracteres, son iguales entre si, o quedan con estos valores de ejemplo.
# Genera cada uno con: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# Azure Blob Storage (PDFs de boletos)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="boletos-pdf"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
