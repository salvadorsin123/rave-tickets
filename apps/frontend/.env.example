# URL interna (servidor-a-servidor) del backend NestJS. Nunca se expone al navegador:
# todas las llamadas del cliente pasan por /api/proxy/* en este mismo origen.
BACKEND_URL="http://localhost:3001"

# Debe coincidir con JWT_ACCESS_EXPIRES_IN / JWT_REFRESH_EXPIRES_IN del backend (en segundos).
ACCESS_TOKEN_MAX_AGE_SECONDS=900
REFRESH_TOKEN_MAX_AGE_SECONDS=604800
