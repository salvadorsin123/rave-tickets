# Copia este archivo a infra/.env para personalizar el stack local de docker-compose.
# Todos los valores tienen defaults de desarrollo en docker-compose.yml; este archivo
# solo es necesario si quieres sobreescribirlos.
#
# Estos valores son SOLO para el stack local (que corre como NODE_ENV=development). El
# despliegue de produccion es en Azure y exige secretos JWT fuertes propios (>=32 chars,
# distintos entre si, no los de ejemplo): se configuran como App Settings, no aqui.

DB_SA_PASSWORD=R4ve!DevPassw0rd
JWT_ACCESS_SECRET=dev-access-secret-cambiar
JWT_REFRESH_SECRET=dev-refresh-secret-cambiar
SEED_ADMIN_EMAIL=admin@rave.local
SEED_ADMIN_PASSWORD=CambiameYa123!
